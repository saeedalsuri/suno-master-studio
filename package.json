{
  "name": "suno-master-studio",
  "version": "6.0.0",
  "description": "SUNO V5 Compliant Music Prompt Generator",
  "author": "Suno Master Team",
  "license": "MIT",
  "main": "electron-main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "vite build && electron-packager . \"Suno Master Studio V6\" --overwrite --platform=win32 --arch=x64 --out=dist_v6 --icon=build/icon01.ico --asar --prune=true --ignore=\"(release-builds|dist_electron|standalone-build|dist_portable|dist_final|dist_v56|release|.git)\""
  },
  "build": {
    "appId": "com.suno.promptmaker",
    "productName": "Suno Master Studio V6",
    "directories": {
      "output": "dist_electron",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron-main.js",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Suno Master Studio V6"
    }
  },
  "dependencies": {
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-packager": "^17.1.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  }
}
